{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Heading": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "Image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Date": {
      "type": "date"
    },
    "Description": {
      "type": "blocks"
    },
    "blog_news": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog-new.blog-new",
      "mappedBy": "blogs"
    }
  }
}
